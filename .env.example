# dbrx-catnat — operator parameters.
# Copy this file to `.env` (gitignored) and edit values for your workspace.
# The `catnat` CLI loads `.env` automatically on startup via python-dotenv.

# Databricks CLI profile (from ~/.databrickscfg).
CATNAT_PROFILE=fevm-stable-po64og

# SQL warehouse used by all pipeline notebooks.
CATNAT_WAREHOUSE_ID=1c97ee257092c2b3

# Parent Unity Catalog. The pipeline nests its schemas (catnat_bronze,
# catnat_silver, catnat_gold) under this catalog. Use `catnat` once we move to
# a workspace where we have CREATE CATALOG on the metastore.
CATNAT_CATALOG=serverless_stable_po64og_catalog

# When `true`, fetchers re-download from upstream even if the file is already
# cached in the bronze raw volume. Default `false`: cache hits skip the network.
CATNAT_FORCE_FETCH=false
